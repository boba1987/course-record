# Copy to .env and adjust. The file .env is gitignored — never commit it.
# docker compose and variable substitution in docker-compose.yml read values from .env.

# MySQL (official image)
MYSQL_DATABASE=course_record
MYSQL_USER=course_record
MYSQL_PASSWORD=local_dev_change_me
MYSQL_ROOT_PASSWORD=local_root_change_me

# Spring Boot (must match MYSQL_USER / MYSQL_PASSWORD for the app DB user)
JWT_SECRET=local_dev_change_me_use_a_long_random_secret_at_least_256_bits

APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=local_dev_change_me
